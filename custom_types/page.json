{
  "Main": {
    "uid": {
      "type": "UID",
      "config": {
        "label": "Slug",
        "placeholder": "URL-Teil nach \"www.deine-url/\""
      }
    },
    "page_title": {
      "type": "StructuredText",
      "config": {
        "single": "heading1",
        "label": "Page title",
        "placeholder": "Seiten Titel"
      }
    },
    "content": {
      "type": "StructuredText",
      "config": {
        "multi": "paragraph,preformatted,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
        "label": "Content",
        "placeholder": "Inhalte"
      }
    },
    "body": {
      "type": "Slices",
      "fieldset": "Slice zone",
      "config": {
        "labels": {
          "akkordeon": [
            {
              "display": "accordion",
              "name": "accordion"
            }
          ]
        },
        "choices": {
          "preisliste": {
            "type": "Slice",
            "fieldset": "Preisliste",
            "description": "Preisliste",
            "icon": "format_list_bulleted",
            "display": "list",
            "non-repeat": {
              "price_section_title": {
                "type": "StructuredText",
                "config": {
                  "single": "heading2,heading3,heading4,heading5,heading6",
                  "label": "Überschrift Preisliten Abschnitt",
                  "placeholder": "Hier Überschrift Preisliten Abschnitt eingeben"
                }
              }
            },
            "repeat": {
              "price_list_title": {
                "type": "StructuredText",
                "config": {
                  "single": "heading3,heading4,heading5,heading6",
                  "label": "Preislisten Überschrift",
                  "placeholder": "Hier Preislisten Überschrift eingeben"
                }
              },
              "price_description": {
                "type": "StructuredText",
                "config": {
                  "multi": "paragraph,preformatted,heading3,heading4,heading5,heading6,strong,em,hyperlink,embed,list-item,o-list-item,rtl",
                  "label": "Preis Beschreibung",
                  "placeholder": "Hier Preis Beschreibung eingeben"
                }
              },
              "price": {
                "type": "Number",
                "config": {
                  "label": "Preis",
                  "placeholder": "Hier Preis eingeben"
                }
              },
              "price_annex": {
                "type": "Select",
                "config": {
                  "options": [
                    "Am beliebtesten",
                    "Empfohlen"
                  ],
                  "label": "Preis Zusatz",
                  "placeholder": "Hier Preis Zusatz auswählen"
                }
              },
              "price_type": {
                "type": "Select",
                "config": {
                  "options": [
                    "Pauschal",
                    "Jährlich"
                  ],
                  "label": "Preis Typ",
                  "placeholder": "Hier Preis Typ auswählen"
                }
              }
            }
          },
          "html_inhalte": {
            "type": "Slice",
            "fieldset": "HTML Inhalte",
            "description": "HTML Code",
            "icon": "code",
            "display": "list",
            "non-repeat": {
              "html_code": {
                "type": "Text",
                "config": {
                  "label": "HTML Code"
                }
              }
            },
            "repeat": {}
          },
          "bild_und_text": {
            "type": "Slice",
            "fieldset": "Bild und Text",
            "description": "Eine Komponente mit Bild und Text",
            "icon": "account_balance_wallet",
            "display": "grid",
            "non-repeat": {},
            "repeat": {
              "picture": {
                "type": "Image",
                "config": {
                  "constraint": {
                    "height": 768
                  },
                  "thumbnails": [
                    {
                      "name": "laptop",
                      "width": 930,
                      "height": null
                    },
                    {
                      "name": "tablet",
                      "width": null,
                      "height": 1024
                    },
                    {
                      "name": "phone_landscape",
                      "width": 350,
                      "height": null
                    }
                  ],
                  "label": "Bild"
                }
              },
              "caption": {
                "type": "StructuredText",
                "config": {
                  "single": "heading3,heading4,heading5,heading6",
                  "label": "Bild Titel"
                }
              },
              "title": {
                "type": "StructuredText",
                "config": {
                  "single": "heading2,heading3,heading4,heading5,heading6",
                  "label": "Überschrift",
                  "placeholder": "Überschrift"
                }
              },
              "text": {
                "type": "StructuredText",
                "config": {
                  "single": "paragraph,preformatted,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,embed,list-item,o-list-item,rtl",
                  "allowTargetBlank": true,
                  "label": "Text",
                  "placeholder": "Text"
                }
              },
              "alignment": {
                "type": "Select",
                "config": {
                  "options": [
                    "Bild rechts Text links",
                    "Text rechts Bild links"
                  ],
                  "default_value": "Bild rechts Text links",
                  "label": "Ausrichtung",
                  "placeholder": "Ausrichtung"
                }
              },
              "top_page_banner": {
                "type": "Boolean",
                "config": {
                  "default_value": false,
                  "label": "Als Seitenbanner verwenden"
                }
              }
            }
          },
          "text_block": {
            "type": "Slice",
            "fieldset": "Text Block",
            "description": "Text Block",
            "icon": "format_color_text",
            "display": "list",
            "non-repeat": {
              "text_block": {
                "type": "StructuredText",
                "config": {
                  "multi": "paragraph,preformatted,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
                  "label": "Text Block"
                }
              }
            },
            "repeat": {}
          },
          "akkordeon": {
            "type": "Slice",
            "fieldset": "Akkordeon",
            "description": "Aus- und Einklappbare Textbereiche",
            "icon": "toc",
            "display": "list",
            "non-repeat": {
              "accordion_title": {
                "type": "StructuredText",
                "config": {
                  "single": "heading2,heading3,heading4,heading5,heading6",
                  "label": "Akkordeon Titel"
                }
              },
              "accordion_explanation_text": {
                "type": "StructuredText",
                "config": {
                  "multi": "paragraph, preformatted, heading4, heading5, heading6, strong, em, hyperlink, image, embed, list-item, o-list-item, rtl",
                  "allowTargetBlank": true,
                  "label": "Akkordeon Erklärungstext"
                }
              }
            },
            "repeat": {
              "accordion_item_title": {
                "type": "StructuredText",
                "config": {
                  "single": "heading3,heading4,heading5,heading6",
                  "label": "Akkordeonartikel Überschrift"
                }
              },
              "accordion_item_text": {
                "type": "StructuredText",
                "config": {
                  "multi": "paragraph,preformatted,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl",
                  "label": "Akkordeonartikel Text"
                }
              }
            }
          }
        }
      }
    }
  },
  "SEO": {
    "site_meta_title": {
      "type": "Text",
      "config": {
        "label": "Seiten Titel"
      }
    },
    "site_meta_description": {
      "type": "Text",
      "config": {
        "label": "Website Beschreibung"
      }
    }
  }
}